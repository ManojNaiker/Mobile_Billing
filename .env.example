# ============================================================
#  BillEase — Environment Variables
#  Copy this file, rename it to .env, and fill in your values.
# ============================================================

# PostgreSQL Database
# Local default:
DATABASE_URL=postgresql://postgres:root@localhost:5432/billease

# Cloud (Neon / Supabase / Railway):
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Server ports (optional — defaults shown)
PORT=5000
API_PORT=8080

# App settings
NODE_ENV=development
LOG_LEVEL=info
BASE_PATH=/
