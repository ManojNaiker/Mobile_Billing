# ============================================================
#  BillEase — Environment Variables
#  Copy this file and rename it to:  .env
#  Then fill in your own values below.
# ============================================================

# --- PostgreSQL Database ---
# Local PostgreSQL (default setup):
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/billease

# Cloud database example (Neon / Supabase / Railway):
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# --- Session Secret (any long random string, keep it secret) ---
SESSION_SECRET=change-this-to-a-long-random-secret-string-minimum-32-chars

# --- Optional Settings ---
NODE_ENV=development
LOG_LEVEL=info
